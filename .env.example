# ── Client (Vite — exposed to browser) ─────────────────────────────────────
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id
# Show Demo Data toggle on first load (presentations)
VITE_DEMO_MODE=false

# ── Server (API routes — never commit real secrets) ────────────────────────
# Option A: Lovable AI Gateway
LOVABLE_API_KEY=
CHAT_MODEL=google/gemini-2.5-flash
TTS_MODEL=openai/gpt-4o-mini-tts
TTS_VOICE=alloy

# Option B: OpenRouter (used when LOVABLE_API_KEY is unset)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=x-ai/grok-4.3
OPENROUTER_TTS_MODEL=x-ai/grok-voice-tts-1.0
  .env.example
# Set the same server vars in: Cloudflare dashboard → Workers → Settings → Variables
# Or: wrangler secret put OPENROUTER_API_KEY
#
# Required for production:
#   VITE_MAPBOX_TOKEN, OPENROUTER_API_KEY (or LOVABLE_API_KEY)
# Optional: Supabase (traits sync), OPENROUTER_TTS_* (voice replies)
# WAQI / aqicn.org live air quality tiles + station data
WAQI_API_KEY=
